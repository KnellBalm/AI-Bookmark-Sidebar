{
  "manifest_version": 3,
  "name": "AI Bookmark Sidebar",
  "description": "북마크 트리를 보고 원하는 URL만 AI 서버로 전송",
  "version": "0.1.0",
  "permissions": ["bookmarks", "sidePanel"],
  "host_permissions": ["http://192.168.101.224:18182/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "북마크 AI 정리"
  }
}
